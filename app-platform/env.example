# Environment variables for HTI-Lab-AgenticAI
# Copy this to .env.local and fill in your API keys.

# ── OpenRouter ──────────────────────────────────────────────────────────────
# API key for real models (GPT-5.4, Claude Sonnet 4.6, Gemini 3.1 Pro)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# API key for test mode (Nemotron — free tier on OpenRouter)
OPENROUTER_API_KEY_TEST=sk-or-v1-your-nemotron-key-here

# ── Code Execution (OneCompiler) ────────────────────────────────────────────
# Get your key at onecompiler.com
ONECOMPILER_API_KEY=oc-your-onecompiler-key-here
